{
  "servers": [
    {
      "name": "Postgres (Sample)",
      "type": "postgres",
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server",
        "--prebuilt=postgres"
      ],
      "env": {
        "POSTGRES_URL": "postgres://user:password@host:port/database"
      },
      "disabled": true
    },
    {
      "name": "E2B (Custom JS)",
      "type": "e2b",
      "command": "node",
      "args": [
        "d:/TEKTILE/mcp-server-main/packages/e2b-js/index.js"
      ],
      "env": {
        "E2B_API_KEY": "e2b_573d9b3a3dc643237112e751f0711ac82fdb36ae"
      }
    }
  ]
}